{
  "name": "ai-video-generator-qa-framework",
  "version": "1.0.0",
  "description": "Production-grade QA automation framework for AI video generation platforms (Runway, Pika, Kling, Sora). TypeScript-first with CI/CD integration.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest --runInBand",
    "test:runway": "jest --testPathPattern=tests/runway",
    "test:pika": "jest --testPathPattern=tests/pika",
    "test:kling": "jest --testPathPattern=tests/kling",
    "test:sora": "jest --testPathPattern=tests/sora",
    "test:cross": "jest --testPathPattern=tests/cross-platform",
    "test:smoke": "jest --testNamePattern='smoke'",
    "test:regression": "jest --testNamePattern='regression'",
    "test:ci": "jest --ci --coverage --runInBand",
    "report": "allure generate allure-results --clean -o allure-report",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "qa", "automation", "ai-video", "runway", "pika", "kling", "typescript", "playwright", "testing"
  ],
  "author": "Sreehari Valluri",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@playwright/test": "^1.43.0",
    "axios": "^1.6.0",
    "dotenv": "^16.4.0",
    "joi": "^17.12.0",
    "winston": "^3.13.0",
    "sharp": "^0.33.0",
    "form-data": "^4.0.0",
    "uuid": "^9.0.0"
  }
}
